# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Build and packaging output
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Test and tooling caches
.cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
.nox/
.pyre/
.pytype/

# Virtual environments and local config
.env
.envrc
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/

# SQLite runtime files
*.db-journal
*.db-wal
*.db-shm
database/*.pre*.db
database/*before*.db
database/*.backup*.db

# Keep the main working DB snapshot for now, but ignore local save files.
saves/*
!saves/.gitkeep

# Generated UI exports. Rebuild them with the export tools when needed.
ui/**/*-data.js

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs and temporary files
logs/
temp/
tmp/
*.log
*.tmp
*.bak
tempCodeRunnerFile.py

# Player headshots are large generated/downloaded assets. Use Git LFS later
# if we decide they should travel with the repo.
graphics/players/**/headshots/
graphics/players/player_headshots_manifest.json

# Generated portrait staging output. Keep queued prompts/manifests trackable,
# but do not commit unapproved image files.
graphics/players/portrait_jobs/staged/**
!graphics/players/portrait_jobs/staged/**/
!graphics/players/portrait_jobs/staged/**/.gitkeep
graphics/players/portrait_jobs/rejected/**
!graphics/players/portrait_jobs/rejected/**/
!graphics/players/portrait_jobs/rejected/**/.gitkeep
